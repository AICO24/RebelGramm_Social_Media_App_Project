rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: public read (for profiles/suggestions), writes restricted to owner
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcollections under a user (followers, following, saved)
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /following/{followingId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /saved/{savedId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Posts: public reads for feed, authenticated writes
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Subcollections on posts (likes, comments)
      match /likes/{likeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Allow reads for common collections used by UI (stories, comments, etc.)
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: deny other writes and reads
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
