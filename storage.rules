rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // DEBUG/DEVELOPMENT: allow reads and authenticated writes.
    // For production, tighten these rules to validate path ownership, file types and sizes.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
